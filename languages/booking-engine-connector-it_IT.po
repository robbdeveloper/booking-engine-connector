#. Plugin Name of the plugin
#: booking-engine-connector.php includes/Admin/AdminMenu.php:107
msgid "Booking Engine Connector"
msgstr "Connettore del Booking Engine"

#. Plugin URI of the plugin
#: booking-engine-connector.php
msgid "https://bec-docs.apps.robb.cx"
msgstr "https://bec-docs.apps.robb.cx"

#. Description of the plugin
#: booking-engine-connector.php
msgid ""
"Connects WordPress to external booking engines (Kross Booking and others) "
"with sync, search context, and checkout links."
msgstr ""
"Collega WordPress a Booking Engines esterni (Kross Booking e altri) con "
"collegamenti di sincronizzazione, contesto di ricerca e pagamento."

#. Author of the plugin
#: booking-engine-connector.php
msgid "RobbDev"
msgstr "RobbDev"

#. Author URI of the plugin
#: booking-engine-connector.php
msgid "https://robbdev.com"
msgstr "https://robbdev.com"

